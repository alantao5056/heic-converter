---
/**
 * Article template: breadcrumb, TL;DR answer box, prose body, FAQ section,
 * download CTA. Emits Article + BreadcrumbList + FAQPage (+ optional HowTo)
 * JSON-LD built from the entry frontmatter.
 */
import type { CollectionEntry } from 'astro:content';
import Base from './Base.astro';
import StoreBadge from '../components/StoreBadge.astro';
import { SITE } from '../site';

interface Props {
  entry: CollectionEntry<'articles'>;
}

const { entry } = Astro.props;
const { title, description, pubDate, updatedDate, tldr, faq, howto } = entry.data;

const canonical = new URL(`/articles/${entry.id}/`, SITE.url).href;
const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const schema: object[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description,
    datePublished: pubDate.toISOString(),
    dateModified: (updatedDate ?? pubDate).toISOString(),
    author: { '@type': 'Person', name: SITE.publisher },
    publisher: { '@type': 'Person', name: SITE.publisher },
    mainEntityOfPage: canonical,
    image: new URL(SITE.ogImage, SITE.url).href,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Guides', item: `${SITE.url}/articles/` },
      { '@type': 'ListItem', position: 3, name: title, item: canonical },
    ],
  },
];

if (faq.length > 0) {
  schema.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  });
}

if (howto) {
  schema.push({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: howto.name,
    step: howto.steps.map((s, i) => ({
      '@type': 'HowToStep',
      position: i + 1,
      name: s.name,
      text: s.text,
    })),
  });
}
---

<Base {title} {description} ogType="article" schema={schema}>
  <article class="article">
    <div class="container narrow">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/articles/">Guides</a>
      </nav>

      <h1>{title}</h1>
      <p class="meta">
        By {SITE.publisher} ·
        <time datetime={pubDate.toISOString().slice(0, 10)}>{dateFmt.format(pubDate)}</time>
        {updatedDate && (
          <>
            {' '}· Updated{' '}
            <time datetime={updatedDate.toISOString().slice(0, 10)}>
              {dateFmt.format(updatedDate)}
            </time>
          </>
        )}
      </p>

      <aside class="tldr">
        <p class="tldr-label">Quick answer</p>
        <p class="tldr-body">{tldr}</p>
      </aside>

      <div class="prose">
        <slot />
      </div>

      {faq.length > 0 && (
        <section class="article-faq" aria-labelledby="faq-heading">
          <h2 id="faq-heading">Frequently asked questions</h2>
          <div class="faq-list">
            {faq.map((f) => (
              <details class="faq-item">
                <summary>{f.q}</summary>
                <p>{f.a}</p>
              </details>
            ))}
          </div>
        </section>
      )}

      <aside class="cta-box">
        <img src="/logo.svg" alt="" width="52" height="52" />
        <div>
          <h2>Convert your whole HEIC library in one run</h2>
          <p>
            HEIC Batch Converter is a free Windows 10/11 app that converts
            folders of HEIC photos to JPG, PNG, GIF, or BMP. Entirely offline,
            with no limits or watermarks.
          </p>
          <StoreBadge />
        </div>
      </aside>
    </div>
  </article>
</Base>

<style>
  .narrow {
    max-width: 780px;
  }

  .article {
    padding-block: clamp(36px, 5vw, 56px) clamp(56px, 7vw, 88px);
  }

  .breadcrumb {
    display: flex;
    gap: 10px;
    font-size: 0.88rem;
    color: var(--ink-faint);
    margin-bottom: 26px;
  }

  h1 {
    font-size: clamp(1.9rem, 3.8vw, 2.7rem);
    font-weight: 750;
  }

  .meta {
    color: var(--ink-faint);
    font-size: 0.9rem;
    margin-bottom: 30px;
  }

  .tldr {
    border: 1px solid rgba(46, 134, 193, 0.3);
    border-left: 4px solid var(--accent);
    background: rgba(46, 134, 193, 0.06);
    border-radius: var(--radius);
    padding: 18px 22px;
    margin-bottom: 36px;
  }

  .tldr-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent-deep);
    margin: 0 0 6px;
  }

  .tldr-body {
    margin: 0;
    font-size: 1.04rem;
    line-height: 1.6;
  }

  .article-faq {
    margin-top: 52px;
  }

  .article-faq h2 {
    font-size: 1.5rem;
    margin-bottom: 18px;
  }

  .faq-list {
    display: grid;
    gap: 10px;
  }

  .faq-item {
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    background: var(--paper);
    padding: 0 18px;
  }

  .faq-item summary {
    cursor: pointer;
    font-weight: 600;
    font-size: 0.97rem;
    padding: 14px 0;
    list-style: none;
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: '+';
    color: var(--accent-deep);
    font-size: 1.2rem;
    font-weight: 400;
    flex: none;
  }

  .faq-item[open] summary::after {
    content: '−';
  }

  .faq-item p {
    margin: 0;
    padding-bottom: 16px;
    color: var(--ink-soft);
    font-size: 0.94rem;
  }

  .cta-box {
    display: flex;
    gap: 22px;
    align-items: flex-start;
    margin-top: 52px;
    padding: 28px;
    border-radius: var(--radius-lg);
    background: linear-gradient(150deg, var(--navy-900), var(--navy-800));
    color: #eaf1f9;
  }

  .cta-box img {
    flex: none;
    margin-top: 4px;
  }

  .cta-box h2 {
    font-size: 1.25rem;
    color: #fff;
    margin-bottom: 8px;
  }

  .cta-box p {
    color: rgba(223, 234, 246, 0.8);
    font-size: 0.95rem;
    margin-bottom: 18px;
  }

  @media (max-width: 560px) {
    .cta-box {
      flex-direction: column;
    }
  }
</style>

<style is:global>
  /* Markdown body typography (unscoped because content is rendered HTML) */
  .prose {
    font-size: 1.02rem;
  }

  .prose h2 {
    font-size: 1.55rem;
    margin-top: 2.2em;
  }

  .prose h3 {
    font-size: 1.18rem;
    margin-top: 1.8em;
  }

  .prose ul,
  .prose ol {
    padding-left: 1.4em;
    margin: 0 0 1.2em;
  }

  .prose li {
    margin-bottom: 0.45em;
  }

  .prose li::marker {
    color: var(--accent-deep);
  }

  .prose strong {
    color: var(--ink);
  }

  .prose blockquote {
    margin: 1.4em 0;
    padding: 4px 20px;
    border-left: 3px solid var(--accent);
    background: var(--paper-tint);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    color: var(--ink-soft);
  }

  .prose code {
    background: var(--paper-tint);
    border: 1px solid var(--border-soft);
    border-radius: 4px;
    padding: 0.1em 0.4em;
    font-size: 0.88em;
  }

  .prose .table-wrap,
  .prose table {
    width: 100%;
  }

  .prose table {
    border-collapse: collapse;
    font-size: 0.93rem;
    margin: 1.4em 0;
    display: block;
    overflow-x: auto;
  }

  .prose th,
  .prose td {
    border: 1px solid var(--border);
    padding: 9px 13px;
    text-align: left;
    vertical-align: top;
  }

  .prose th {
    background: var(--paper-tint);
    font-weight: 650;
    white-space: nowrap;
  }

  .prose hr {
    border: none;
    border-top: 1px solid var(--border-soft);
    margin: 2.4em 0;
  }
</style>
