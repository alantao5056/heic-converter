---
/**
 * Licensing page. Written primarily for IT and procurement reviewers who need
 * to confirm commercial use before deploying the app, so the verdict and the
 * permitted/not-permitted summary come before the full agreement text.
 * Kept in sync with LICENSE.txt at the repository root, which is the copy
 * shipped inside the MSIX.
 */
import Base from '../layouts/Base.astro';
import { SITE } from '../site';

const title = 'License & commercial use | HEIC Batch Converter';
const description =
  'Licence terms for the current release of HEIC Batch Converter, including use within an organisation, together with the third-party open-source notices.';

const effectiveDate = '2026-07-23';
const effectiveLabel = '23 July 2026';

const allowed = [
  'Use inside a company, government body, school, or other organisation',
  'Installation on the devices you own, operate, or administer',
  'Deployment to company devices by an IT administrator',
  'Commercial work, including client deliverables and paid projects',
  'Use of every converted image, with no attribution required',
];

const notAllowed = [
  'Selling, renting, or sublicensing the app, or charging anyone for it',
  'Redistributing it outside your organisation, or bundling it into another product',
  'Modifying, reverse engineering, or decompiling it (see section 5 for the LGPL exception)',
  'Removing copyright or third-party notices',
  'Implying that we endorse you or your products',
];

const faq = [
  {
    q: 'Can HEIC Batch Converter be used for business or commercial purposes?',
    a: 'The licence for the current release permits use within a company, government body, educational institution, or other organisation. See section 2 of the agreement on this page.',
  },
  {
    q: 'Is there a licence fee, seat count, or volume agreement?',
    a: 'No fee applies to the current release, and there is no seat count or volume agreement to sign.',
  },
  {
    q: 'Can an IT administrator deploy it across the organisation?',
    a: 'The current release may be deployed to an organisation\'s own devices by any means Microsoft makes available for distributing Microsoft Store applications, and installed on behalf of its personnel.',
  },
  {
    q: 'Is HEIC Batch Converter open source?',
    a: 'No. It is proprietary software and its source code is not available. It does include open-source components, which are listed in the third-party notices along with their licences.',
  },
  {
    q: 'Do converted images carry any licence restriction or watermark?',
    a: 'No. The publisher claims no right in the images the app produces, and there are no watermarks or attribution requirements.',
  },
  {
    q: 'Does the app upload images or require an internet connection?',
    a: 'In the current release, all conversion happens on the local device. It does not upload images, does not transmit their contents or filenames, and works offline.',
  },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faq.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'License', item: `${SITE.url}/license/` },
    ],
  },
];
---

<Base {title} {description} {schema}>
  <article class="license">
    <div class="container narrow">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span>License</span>
      </nav>

      <p class="eyebrow">Licensing</p>
      <h1>License &amp; commercial use</h1>
      <p class="meta">
        Effective <time datetime={effectiveDate}>{effectiveLabel}</time> · Applies to
        HEIC Batch Converter version 2.1
      </p>

      <aside class="tldr">
        <p class="tldr-label">Summary for IT and procurement</p>
        <p class="tldr-body">
          The current release of HEIC Batch Converter may be used within a company
          or other organisation, including for commercial work, at no charge. The
          terms set out on this page apply to that release.
        </p>
      </aside>

      <section class="perms" aria-label="Summary of permitted and prohibited use">
        <div class="perm-col yes">
          <h2>What you may do</h2>
          <ul>{allowed.map((item) => <li>{item}</li>)}</ul>
        </div>
        <div class="perm-col no">
          <h2>What you may not do</h2>
          <ul>{notAllowed.map((item) => <li>{item}</li>)}</ul>
        </div>
      </section>

      <p class="note">
        The summary above is provided for convenience. The agreement below is the
        operative text.
      </p>

      <div class="prose">
        <h2 id="agreement">End-User License Agreement</h2>

        <p>
          This End-User License Agreement ("Agreement") is a legal agreement between
          you, either an individual or a single legal entity ("you"), and Alan Tao
          ("we", "us") governing your use of the HEIC Batch Converter software
          application, including all files distributed with it (the "Software").
        </p>
        <p>
          By installing or using the Software you accept this Agreement. If you do
          not accept it, do not install or use the Software.
        </p>

        <h3>1. License grant</h3>
        <p>
          We grant you a non-exclusive, worldwide, royalty-free, perpetual license to
          install and use the Software, subject to the terms of this Agreement.
        </p>
        <p>
          The Software is provided free of charge. No fee, purchase, subscription,
          registration, activation key, or seat count applies.
        </p>

        <h3>2. Permitted use</h3>
        <ol>
          <li>
            <strong>Business and commercial use is permitted.</strong> You may use
            the Software for any lawful purpose, including internal business use
            within a company, government body, educational institution, or other
            organisation.
          </li>
          <li>
            <strong>No limit applies to the number of devices or users.</strong> You
            may install the Software on any number of devices that you own, operate,
            or administer, and any number of your personnel may use it.
          </li>
          <li>
            <strong>Deployment by administrators is permitted.</strong> An
            organisation may deploy the Software to its own devices by any means made
            available by Microsoft for the distribution of Microsoft Store
            applications, and may install it on behalf of its personnel.
          </li>
          <li>
            <strong>Output files are yours.</strong> We claim no right in, and impose
            no restriction on, the image files the Software produces. You may use,
            publish, and sell them freely. No attribution to us is required.
          </li>
          <li>
            <strong>No reporting obligation.</strong> You need not notify us of your
            use, and need not obtain any further permission beyond this Agreement.
          </li>
        </ol>

        <h3>3. Restrictions</h3>
        <p>Except as section 6 provides, you may not:</p>
        <ol>
          <li>
            sell, rent, lease, lend, or sublicense the Software, or charge any third
            party for it;
          </li>
          <li>
            distribute the Software outside your own organisation, including by
            mirroring, re-hosting, repackaging, or bundling it with another product
            or service;
          </li>
          <li>
            modify, adapt, translate, or create derivative works of the Software;
          </li>
          <li>reverse engineer, decompile, or disassemble the Software;</li>
          <li>
