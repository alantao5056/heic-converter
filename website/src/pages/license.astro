              <tr><td>libraw</td><td>0.22.1</td><td>LGPL-2.1</td></tr>
              <tr><td>glib, gdk-pixbuf, fribidi, liblzma</td><td>various</td><td>LGPL-2.1-or-later</td></tr>
              <tr><td>pango, librsvg, libcroco</td><td>various</td><td>LGPL-2.0-or-later</td></tr>
