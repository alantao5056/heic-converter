<style>
  .narrow {
    max-width: 780px;
  }

  .license {
    padding-block: clamp(36px, 5vw, 56px) clamp(56px, 7vw, 88px);
  }

  .breadcrumb {
    display: flex;
    gap: 10px;
    font-size: 0.88rem;
    color: var(--ink-faint);
    margin-bottom: 26px;
  }

  h1 {
    font-size: clamp(1.9rem, 3.8vw, 2.7rem);
    font-weight: 750;
  }

  .meta {
    color: var(--ink-faint);
    font-size: 0.9rem;
    margin-bottom: 30px;
  }

  .tldr {
    border: 1px solid rgba(46, 134, 193, 0.3);
    border-left: 4px solid var(--accent);
    background: rgba(46, 134, 193, 0.06);
    border-radius: var(--radius);
    padding: 18px 22px;
    margin-bottom: 32px;
  }

  .tldr-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent-deep);
    margin: 0 0 6px;
  }

  .tldr-body {
    margin: 0;
    font-size: 1.04rem;
    line-height: 1.6;
  }

  .perms {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin-bottom: 22px;
  }

  .perm-col {
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    background: var(--paper);
    box-shadow: var(--shadow-card);
    padding: 20px 22px;
  }

  .perm-col h2 {
    font-size: 1rem;
    font-weight: 650;
    margin-bottom: 14px;
  }

  .perm-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 10px;
  }

  .perm-col li {
    position: relative;
    padding-left: 26px;
    font-size: 0.93rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .perm-col li::before {
    position: absolute;
    left: 0;
    top: -1px;
    font-weight: 700;
    font-size: 1rem;
  }

  .yes li::before {
    content: '✓';
    color: var(--c-green);
  }

  .no li::before {
    content: '✕';
    color: var(--c-red);
  }

  .note {
    font-size: 0.9rem;
    color: var(--ink-faint);
    margin-bottom: 40px;
  }

  .note code {
    background: var(--paper-tint);
    border: 1px solid var(--border-soft);
    border-radius: 4px;
    padding: 0.1em 0.4em;
    font-size: 0.9em;
  }

  .faq-list {
    display: grid;
    gap: 10px;
  }

  .faq-item {
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    background: var(--paper);
    padding: 0 18px;
  }

  .faq-item summary {
    cursor: pointer;
    font-weight: 600;
    font-size: 0.97rem;
    padding: 14px 0;
    list-style: none;
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: '+';
    color: var(--accent-deep);
    font-size: 1.2rem;
    font-weight: 400;
    flex: none;
  }

  .faq-item[open] summary::after {
    content: '−';
  }

  .faq-item p {
    margin: 0;
    padding-bottom: 16px;
    color: var(--ink-soft);
    font-size: 0.94rem;
  }

  .contact-box {
    margin-top: 52px;
    padding: 26px 28px;
    border-radius: var(--radius-lg);
    background: linear-gradient(150deg, var(--navy-900), var(--navy-800));
    color: rgba(223, 234, 246, 0.85);
  }

  .contact-box h2 {
    font-size: 1.2rem;
    color: #fff;
    margin-bottom: 8px;
  }

  .contact-box p {
    margin: 0;
    font-size: 0.95rem;
  }

  .contact-box a {
    color: var(--accent-bright);
  }

  @media (max-width: 640px) {
    .perms {
      grid-template-columns: 1fr;
    }
  }
</style>

<style is:global>
  /* The agreement body reuses the article prose rules; these are the additions
     specific to legal copy. */
  .license .prose h2 {
    font-size: 1.5rem;
    margin-top: 2.4em;
    padding-top: 1.4em;
    border-top: 1px solid var(--border-soft);
  }

  .license .prose h3 {
    font-size: 1.08rem;
    margin-top: 1.9em;
  }

  .license .prose ol {
    padding-left: 1.4em;
    margin: 0 0 1.2em;
  }

  .license .prose li {
    margin-bottom: 0.55em;
  }

  .license .prose li::marker {
    color: var(--accent-deep);
  }

  .license .prose code {
    background: var(--paper-tint);
    border: 1px solid var(--border-soft);
    border-radius: 4px;
    padding: 0.1em 0.4em;
    font-size: 0.88em;
  }

  .license .prose table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    margin: 1.2em 0 1.6em;
  }

  .license .prose .table-wrap {
    overflow-x: auto;
  }

  .license .prose th,
  .license .prose td {
    border: 1px solid var(--border);
    padding: 9px 13px;
    text-align: left;
    vertical-align: top;
  }

  .license .prose th {
    background: var(--paper-tint);
    font-weight: 650;
    white-space: nowrap;
  }

  .license .prose .legal-caps {
    font-size: 0.88rem;
    color: var(--ink-soft);
    line-height: 1.7;
  }
</style>
