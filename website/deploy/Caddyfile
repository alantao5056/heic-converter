# Caddy site block for the GEO content site.
# Merge into the server's /etc/caddy/Caddyfile, then: sudo systemctl reload caddy
# HTTPS certificates are provisioned automatically via Let's Encrypt.

heicbatchconverter.alantao.com {
    root * /var/www/heicbatchconverter
    file_server
    encode zstd gzip

    # Immutable fingerprinted assets
    @assets path /_astro/*
    header @assets Cache-Control "public, max-age=31536000, immutable"
}
