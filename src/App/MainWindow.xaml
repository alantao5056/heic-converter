<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Alan.HeicConverter.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Alan.HeicConverter"
    xmlns:Models="using:Alan.HeicConverter.Models"
    xmlns:Services="using:Alan.HeicConverter.Services"
    xmlns:controls="using:Alan.HeicConverter.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Heic Batch Converter">

    <Grid>
        <Grid.Resources>
            <Style x:Key="FormatToggleButtonStyle" TargetType="ToggleButton" BasedOn="{StaticResource DefaultToggleButtonStyle}">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Padding" Value="0,6" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="FolderPathTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource DefaultTextBoxStyle}">
                <Setter Property="IsReadOnly" Value="True" />
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryColor}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="MinHeight" Value="28" />
                <Setter Property="Padding" Value="10,6" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderLightColor}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="4" />
            </Style>

            <Style x:Key="SidebarTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource FolderPathTextBoxStyle}">
                <Setter Property="Background" Value="{StaticResource MainBackground}" />
            </Style>

            <Style x:Key="MainPanelTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource FolderPathTextBoxStyle}">
                <Setter Property="Background" Value="{StaticResource SidebarBackground}" />
            </Style>

            <Style x:Key="BrowseButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Margin" Value="8,0,0,0" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderMidColor}" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryColor}" />
            </Style>
        </Grid.Resources>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="232" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        
        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBackground}" BorderBrush="{StaticResource BorderLightColor}" BorderThickness="0,0,1,0">
            <Border.Resources>
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#FFFFFF" />
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#FFFFFF" />
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#1E000000" />
                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#1E000000" />
            </Border.Resources>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" Padding="16,20,16,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="20">
                        <!-- Header -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="HEIC Batch Converter" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryColor}" />
                            <TextBlock Text="Version 1.0.0" FontSize="11" Foreground="{StaticResource TextTertiaryColor}" Margin="0,0,0,12" />
                            <MenuFlyoutSeparator Background="{StaticResource BorderLightColor}" Margin="-16,0" />
                        </StackPanel>
                        
                        <!-- Search scope -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Search scope" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentColor}" />
                            <CheckBox x:Name="IncludeSubfoldersCheckBox" Content="Include subfolders" FontSize="12" Foreground="{StaticResource TextSecondaryColor}" VerticalContentAlignment="Center" Padding="7,0" Checked="IncludeSubfoldersCheckBox_CheckedChanged" Unchecked="IncludeSubfoldersCheckBox_CheckedChanged" />
                        </StackPanel>
                        
                        <!-- Output format -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Output format" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentColor}" />
                            <Grid ColumnSpacing="6" RowSpacing="6">
                                <Grid.Resources>
                                    <SolidColorBrush x:Key="ToggleButtonBackground" Color="#FFFFFF" />
                                    <SolidColorBrush x:Key="ToggleButtonForeground" Color="#5F5E5A" />
                                    <SolidColorBrush x:Key="ToggleButtonBorderBrush" Color="#1E000000" />
                                    
                                    <SolidColorBrush x:Key="ToggleButtonBackgroundPointerOver" Color="#F3F3F0" />
                                    <SolidColorBrush x:Key="ToggleButtonForegroundPointerOver" Color="#5F5E5A" />
                                    <SolidColorBrush x:Key="ToggleButtonBorderBrushPointerOver" Color="#1E000000" />

                                    <SolidColorBrush x:Key="ToggleButtonBackgroundPressed" Color="#E5E5E2" />
                                    <SolidColorBrush x:Key="ToggleButtonForegroundPressed" Color="#5F5E5A" />
                                    <SolidColorBrush x:Key="ToggleButtonBorderBrushPressed" Color="#38000000" />

                                    <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="#E6F1FB" />
                                    <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="#185FA5" />
                                    <SolidColorBrush x:Key="ToggleButtonBorderBrushChecked" Color="#185FA5" />
                                    
                                    <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="#E6F1FB" />
                                    <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="#185FA5" />
                                    <SolidColorBrush x:Key="ToggleButtonBorderBrushCheckedPointerOver" Color="#185FA5" />

                                    <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed" Color="#E6F1FB" />
                                    <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPressed" Color="#185FA5" />
                                    <SolidColorBrush x:Key="ToggleButtonBorderBrushCheckedPressed" Color="#185FA5" />
                                </Grid.Resources>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ToggleButton x:Name="JpgButton" Content="JPG" Style="{StaticResource FormatToggleButtonStyle}" Grid.Row="0" Grid.Column="0" IsChecked="True" Click="FormatButton_Click" />
                                <ToggleButton x:Name="PngButton" Content="PNG" Style="{StaticResource FormatToggleButtonStyle}" Grid.Row="0" Grid.Column="1" Click="FormatButton_Click" />
                                <ToggleButton x:Name="GifButton" Content="GIF" Style="{StaticResource FormatToggleButtonStyle}" Grid.Row="1" Grid.Column="0" Click="FormatButton_Click" />
                                <ToggleButton x:Name="BmpButton" Content="BMP" Style="{StaticResource FormatToggleButtonStyle}" Grid.Row="1" Grid.Column="1" Click="FormatButton_Click" />
                            </Grid>
                        </StackPanel>
                        
                        <!-- JPG quality -->
                        <StackPanel x:Name="JpgQualityPanel" Spacing="8">
                            <Grid>
                                <TextBlock Text="JPG quality" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AccentColor}" HorizontalAlignment="Left" />
                                <TextBlock x:Name="JpgQualityText" Text="85%" FontSize="12" FontWeight="Medium" Foreground="{StaticResource AccentColor}" HorizontalAlignment="Right" />
                            </Grid>
                            <Slider x:Name="JpgQualitySlider" Minimum="1" Maximum="100" Value="85" Foreground="{StaticResource AccentColor}" ValueChanged="JpgQualitySlider_ValueChanged" />
                        </StackPanel>
                        
                        <!-- Conflict resolution -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Conflict resolution" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AccentColor}" />
                            <ComboBox x:Name="ConflictResolutionComboBox" HorizontalAlignment="Stretch" SelectedIndex="0" FontSize="13" VerticalContentAlignment="Center" Padding="12,0,0,0" MinHeight="32">
                                <ComboBoxItem Content="Generate unique name" />
                                <ComboBoxItem Content="Replace" />
                                <ComboBoxItem Content="Ignore" />
                            </ComboBox>
                        </StackPanel>
                        
                        <!-- Original file handling -->
                        <StackPanel Spacing="8" Margin="0,0,0,20">
                            <TextBlock Text="Original file handling" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AccentColor}" />
                            <ComboBox x:Name="OriginalFileHandlingComboBox" ItemsSource="{x:Bind FileHandlingOptions}" DisplayMemberPath="DisplayName" SelectedValuePath="Value" HorizontalAlignment="Stretch" FontSize="13" SelectionChanged="OriginalFileHandlingComboBox_SelectionChanged" VerticalContentAlignment="Center" Padding="12,0,0,0" MinHeight="32" />
                            <!-- Conditional Path (mocked as collapsed) -->
                            <Grid x:Name="CustomPathGrid" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="CustomPathTextBox" Grid.Column="0" Text="" PlaceholderText="Select a folder..." Style="{StaticResource SidebarTextBoxStyle}" />
                                <Button x:Name="BrowseCustomPathButton" Grid.Column="1" Style="{StaticResource BrowseButtonStyle}" Click="BrowseCustomPathButton_Click">
                                    <FontIcon Glyph="&#xED25;" FontSize="16" />
                                </Button>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
                
                <!-- Stats row -->
                <Border Grid.Row="1" BorderBrush="{StaticResource BorderLightColor}" BorderThickness="0,1,0,0" Height="44">
                    <Grid Padding="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource GreenBgColor}" BorderBrush="{StaticResource GreenBorderColor}" BorderThickness="1" CornerRadius="4" VerticalAlignment="Center" Padding="0,4">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5">
                                <FontIcon Glyph="&#xE73E;" FontSize="10" Foreground="{StaticResource GreenTextColor}" />
                                <TextBlock x:Name="StatsDoneTextBlock" Text="0 done" FontSize="12" FontWeight="Medium" Foreground="{StaticResource GreenTextColor}" />
                            </StackPanel>
                        </Border>
                        
                        <Border Grid.Column="2" Background="{StaticResource RedBgColor}" BorderBrush="{StaticResource RedBorderColor}" BorderThickness="1" CornerRadius="4" VerticalAlignment="Center" Padding="0,4">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5">
                                <FontIcon Glyph="&#xE711;" FontSize="10" Foreground="{StaticResource RedTextColor}" />
                                <TextBlock x:Name="StatsFailedTextBlock" Text="0 failed" FontSize="12" FontWeight="Medium" Foreground="{StaticResource RedTextColor}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Main Panel -->
        <Grid Grid.Column="1" Background="{StaticResource MainBackground}">
            <Grid.Resources>
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#F3F3F0" />
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#F3F3F0" />
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#1E000000" />
                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#1E000000" />
            </Grid.Resources>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <!-- Topbar -->
            <Border Grid.Row="0" BorderBrush="{StaticResource BorderLightColor}" BorderThickness="0,0,0,1" Padding="20,14">
                <StackPanel Spacing="10">
                    <StackPanel Spacing="5">
                        <TextBlock Text="SOURCE FOLDER" FontSize="10" FontWeight="Medium" Foreground="{StaticResource TextTertiaryColor}" CharacterSpacing="60" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SourceFolderTextBox" Grid.Column="0" Text="" Style="{StaticResource MainPanelTextBoxStyle}" />
                            <Button x:Name="BrowseSourceFolderButton" Grid.Column="1" Style="{StaticResource BrowseButtonStyle}" Click="BrowseSourceFolderButton_Click">
                                <FontIcon Glyph="&#xED25;" FontSize="16" />
                            </Button>
                        </Grid>
                    </StackPanel>
                    <StackPanel Spacing="5">
                        <TextBlock Text="TARGET FOLDER" FontSize="10" FontWeight="Medium" Foreground="{StaticResource TextTertiaryColor}" CharacterSpacing="60" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TargetFolderTextBox" Grid.Column="0" Text="" Style="{StaticResource MainPanelTextBoxStyle}" />
                            <Button x:Name="BrowseTargetFolderButton" Grid.Column="1" Style="{StaticResource BrowseButtonStyle}" Click="BrowseTargetFolderButton_Click">
                                <FontIcon Glyph="&#xED25;" FontSize="16" />
                            </Button>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Action Bar -->
            <Border Grid.Row="1" BorderBrush="{StaticResource BorderLightColor}" BorderThickness="0,0,0,1" Padding="20,10">
                <Button x:Name="StartConversionButton" Click="StartConversionButton_Click" Background="{StaticResource PrimaryButtonBackground}" Foreground="White" HorizontalAlignment="Right" Padding="12,8" CornerRadius="4" IsEnabled="False">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1A6FA0" />
                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#155B84" />
                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White" />
                        
                        <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#B32E86C1" />
                        <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#D9FFFFFF" />
                        <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="Transparent" />
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE768;" FontSize="14" />
                        <TextBlock Text="Start conversion" FontSize="14" FontWeight="Medium" />
                    </StackPanel>
                </Button>
            </Border>
            
            <!-- File Table -->
            <ListView x:Name="FileListView" Grid.Row="2" SelectionMode="None">
                <ListView.Header>
                    <Grid Padding="16,8" BorderBrush="{StaticResource BorderLightColor}" BorderThickness="0,0,0,1" Background="{StaticResource MainBackground}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="148" />
                            <ColumnDefinition Width="136" />
                            <ColumnDefinition Width="136" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="PATH" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentColor}" CharacterSpacing="60" />
                        <TextBlock Grid.Column="1" Text="ORIGINAL NAME" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentColor}" CharacterSpacing="60" />
                        <TextBlock Grid.Column="2" Text="CONVERTED NAME" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentColor}" CharacterSpacing="60" />
                        <TextBlock Grid.Column="3" Text="STATUS" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentColor}" CharacterSpacing="60" />
                    </Grid>
                </ListView.Header>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="Models:FileItem">
                        <Grid Padding="16,6" BorderBrush="{StaticResource BorderLightColor}" BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="148" />
                                <ColumnDefinition Width="136" />
                                <ColumnDefinition Width="136" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind Path}" Foreground="{StaticResource TextSecondaryColor}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" Text="{x:Bind OriginalName}" Foreground="{StaticResource TextSecondaryColor}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="2" Text="{x:Bind ConvertedName, Mode=OneWay}" Foreground="{StaticResource AccentColor}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,10,0" />
                            
                            <controls:FileStatusBadge Grid.Column="3" Status="{x:Bind Status, Mode=OneWay}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="MinHeight" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
            
            <!-- Footer -->
            <Border Grid.Row="3" BorderBrush="{StaticResource BorderLightColor}" BorderThickness="0,1,0,0" Height="44" Padding="20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ProgressBar x:Name="ConversionProgressBar" Grid.Column="0" Value="0" Maximum="100" Height="5" Foreground="{StaticResource AccentColor}" Background="{StaticResource BorderLightColor}" VerticalAlignment="Center" Margin="0,0,14,0" />
                    <TextBlock x:Name="FileCountTextBlock" Grid.Column="1" Text="0 / 0 files" FontSize="12" Foreground="{StaticResource TextTertiaryColor}" VerticalAlignment="Center" Margin="0,0,14,0" />
                    <TextBlock x:Name="PercentageTextBlock" Grid.Column="2" Text="0%" FontSize="12" FontWeight="Medium" Foreground="{StaticResource AccentColor}" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>